DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/scalescrape
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

ENABLE_REAL_2CAPTCHA=false
TWO_CAPTCHA_API_KEY=
ALLOWED_CAPTCHA_HOSTS=target-site,localhost,127.0.0.1
MAX_CAPTCHA_SOLVES_PER_RUN=20
TARGET_SITE_USERNAME=demo
TARGET_SITE_PASSWORD=demo123
# Apenas para teste local com MockCaptchaResolverProvider. Nao use no deploy real.
TARGET_SITE_FIXED_CAPTCHA_ANSWER=ABCDE

ENABLE_PROXY_ROTATION=true
ALLOWED_PROXY_TARGET_HOSTS=target-site,localhost,127.0.0.1
PROXY_COOLDOWN_SECONDS=300
MAX_CONCURRENT_JOBS_PER_PROXY=3

SCRAPER_MAX_ATTEMPTS=3
SCRAPER_PAGE_TIMEOUT_SECONDS=30
SCRAPER_JOB_TIMEOUT_SECONDS=180

